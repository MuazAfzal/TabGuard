{
  "name": "TabGuard",
  "description": "AI-Powered Browser Security Scanner",
  "version": "2.1.0",
  "manifest_version": 3,

  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "action": {
    "default_title": "TabGuard",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },

  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "offscreen",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequestFeedback"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://api-inference.huggingface.co/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "tfjs_model/*",
        "lib/tfjs/*",
        "tfjs/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}